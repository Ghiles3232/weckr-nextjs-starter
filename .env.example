# Weckr. Create a project and copy its key from https://useweckr.com
WECKR_API_KEY=wk_your_key_here

# OpenAI. https://platform.openai.com/api-keys
OPENAI_API_KEY=sk_your_openai_key_here

# Supabase. Project Settings then API. The anon key is safe in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your_project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe. Optional, only needed for the upgrade button. https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PRICE_ID=price_your_price_id

# Public app url, used for Stripe redirects.
NEXT_PUBLIC_APP_URL=http://localhost:3000
